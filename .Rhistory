m8.simple2<-glm(Disease~Age_cen+factor(Sector), family=binomial(link=probit), data=data)
summary(m8.simple2)
logLik(m8.simple2)
probit_simple_mu_hat<-predict(m8.simple2)
cor_probit_simple<-cor(probit_simple_mu_hat, Disease)
cor_probit_simple
roc(Disease, predict(m8.simple2, type = "response"))
roc_probit_simple <- roc(Disease, predict(m8.simple2, type = "response"))
auc<-c(auc(roc_logit), auc(roc_ZIB), auc(roc_best), auc(roc_simple),
auc(roc_probit), auc(roc_probit_ZIB), auc(roc_probit_best), auc(roc_probit_simple))
plot(auc, type="b", xlab="Model", ylab="AUC",
main = "Model AUC Comparison", xaxt="n")
axis(1, seq(1,9))
abline(h=max(auc), col="red")
auc<-c(auc(roc_logit), auc(roc_ZIB), auc(roc_best), auc(roc_simple),
auc(roc_probit), auc(roc_probit_ZIB), auc(roc_probit_best), auc(roc_probit_simple))
plot(auc, type="b", xlab="Model", ylab="AUC",
main = "Model AUC Comparison", xaxt="n")
axis(1, seq(1,10))
abline(h=max(auc), col="red")
auc<-c(auc(roc_logit), auc(roc_ZIB), auc(roc_best), auc(roc_simple),
auc(roc_probit), auc(roc_probit_ZIB), auc(roc_probit_best), auc(roc_probit_simple))
plot(auc, type="b", xlab="Model", ylab="AUC",
main = "Model AUC Comparison", xaxt="n")
axis(1, seq(1,8))
abline(h=max(auc), col="red")
plot(roc_logit, col="blue", main="Roc curve")
lines(roc_ZIB, col="red")
lines(roc_best, col="purple")
lines(roc_simple, col="green")
lines(roc_probit, col="black")
lines(roc_probit_ZIB, col="cyan")
lines(roc_probit_best, col="orange")
lines(roc_probit_simple, col="gray")
legend("bottomright",
legend = c("m1.logit", "m2.ZIB", "m3.best","m4.simple",
"m5.probit", "m6.probit ZIB", "m7.probit best", "m8.probit simple"),
col = c("blue", "red","purple", "green","black","cyan","orange","gray"),
lty = 1)
